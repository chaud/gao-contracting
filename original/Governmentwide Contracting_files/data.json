var textData = {"fy": 2025, "sourceDate": "April 2026", "intro": "The federal government obligated $793 billion through contracts in fiscal year 2025, a $17.8 billion increase from fiscal year 2024 after adjusting for inflation.", "psc": "Most civilian agency spending was for services whereas defense agencies spent slightly more on products than services. ", "comp": "The overall competition rate in fiscal year 2025 was 66%, the same as fiscal year 2024. Civilian agencies' competition rate was 89% and Defense agencies about 52%. ", "sb": "To promote small business participation in federal contracting, there is a government-wide goal to award about a quarter of contract dollars to small businesses.", "ota1": "Other transaction agreements offer agencies a flexible way to purchase goods and services. In fiscal year 2025, agencies reported $18.2 billion in spending on these agreements, a $700 million decrease from fiscal year 2024.", "ota2": "Data on other transaction agreements are not included in data on federal contract obligations.", "NaN": "All obligation amounts are presented in constant FY 2024 dollars. The figures above exclude missing or \u201cother\u201d values that represent less than one percent of total obligations."};